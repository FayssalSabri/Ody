{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@odyssey/shared": ["packages/shared/src/index.ts"],
      "@odyssey/types": ["packages/types/src/index.ts"],
      "@odyssey/api-client": ["packages/api-client/src/index.ts"]
    }
  }
}
